    {
      "parameters": {
        "jsCode": "// Fan out one item per agent in agent_user_ids (comma separated).\nconst base = $('Handover prep').first().json;\nconst agentIds = (base.settings.agent_user_ids || '')\n  .split(',').map(s => s.trim()).filter(Boolean);\nif (!agentIds.length) return [];\nreturn agentIds.map(id => ({ json: { ...base, agentId: id } }));\n"
      },
      "id": "fanout-agents",
      "name": "Fan out agents",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, -200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.line.me/v2/bot/message/push",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.settings.line_channel_access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"to\": {{ JSON.stringify($json.agentId) }},\n  \"messages\": [{ \"type\": \"text\", \"text\": {{ JSON.stringify('🔔 真人通知：【' + $json.nickname + '】正在呼叫專人。\\n觸發字：' + $json.matchedKeyword + '\\n原文：' + $json.userMessage) }} }]\n}",
        "options": {}
      },
      "id": "push-agents",
      "name": "Push to agents",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, -200],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Inline human-mode + timeout check (ported from line-webhook.ts L87-96).\nconst base = $('Detect keyword + state').first().json;\nconst { settings, userState } = base;\nlet action = 'ai';      // ai | silent\nlet needsRevert = false;\nif (userState && userState.is_human_mode) {\n  const last = new Date(userState.last_human_interaction).getTime();\n  const timeoutMs = (Number(settings.handover_timeout_minutes) || 30) * 60 * 1000;\n  if (Date.now() - last < timeoutMs) {\n    action = 'silent';     // still within human window → do not reply with AI\n  } else {\n    needsRevert = true;    // expired → revert to AI and continue\n  }\n}\nif (!settings.is_ai_enabled) action = 'silent';\nreturn [{ json: { ...base, action, needsRevert } }];\n"
      },
      "id": "mode-check",
      "name": "Human-mode + timeout",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-160, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            { "id": "ai", "leftValue": "={{ $json.action }}", "rightValue": "ai", "operator": { "type": "string", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-proceed-ai",
      "name": "Proceed to AI?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [80, 200]
    },
