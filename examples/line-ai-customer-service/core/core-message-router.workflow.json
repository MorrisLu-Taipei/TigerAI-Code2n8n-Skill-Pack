    {
      "parameters": {
        "method": "POST",
        "url": "https://api.line.me/v2/bot/message/reply",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $('Handover prep').item.json.settings.line_channel_access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"replyToken\": {{ JSON.stringify($('Handover prep').item.json.event.replyToken) }},\n  \"messages\": [{ \"type\": \"text\", \"text\": \"已為您轉接真人客服，請稍候。\" }]\n}",
        "options": {}
