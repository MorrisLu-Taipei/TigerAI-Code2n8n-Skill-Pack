    {
      "parameters": {
        "jsCode": "// Resolve nickname + decide update vs create for user_states.\nconst base = $('Detect keyword + state').first().json;\nconst profile = $input.first().json || {};\nconst nickname = profile.displayName || (base.userState && base.userState.nickname) || '匿名用戶';\nconst now = new Date().toISOString();\nreturn [{ json: { ...base, nickname, nowIso: now, userExists: !!base.userState } }];\n"
      },
