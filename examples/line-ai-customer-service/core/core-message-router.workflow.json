      "credentials": { "supabaseApi": { "id": "REPLACE_SUPABASE_CRED_ID", "name": "Supabase account" } },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "content": "### Dedup error output = duplicate\n\nPK conflict on `event_id` means LINE re-sent this event (retry). The error output is a dead-end NoOp — we intentionally do nothing so we never double-reply or roll back state. Matches `if (eventError) continue;` in the original.",
        "height": 200,
        "width": 360,
        "color": 3
      },
      "id": "sticky-dedup",
      "name": "Why error output",
      "type": "n8n-nodes-base.stickyNote",
