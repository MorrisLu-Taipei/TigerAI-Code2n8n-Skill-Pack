    {
      "parameters": {
        "resource": "row",
        "operation": "getAll",
        "tableId": "user_states",
        "returnAll": false,
        "limit": 1,
        "filters": {
          "conditions": [
            { "keyName": "line_user_id", "condition": "eq", "keyValue": "={{ $('When Called').item.json.event.userId }}" }
          ]
        }
      },
      "id": "read-state",
      "name": "Read user_states",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [-880, 0],
      "credentials": { "supabaseApi": { "id": "REPLACE_SUPABASE_CRED_ID", "name": "Supabase account" } },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Assemble state + run keyword detection (ported from line-webhook.ts L52-62).\nconst { event, settings } = $('When Called').first().json;\nconst rows = $input.all();\nconst userState = (rows.length && rows[0].json && rows[0].json.line_user_id) ? rows[0].json : null;\n\nconst userMessage = String(event.text || '').trim();\nconst handoverKeywords = (settings.handover_keywords || '')\n  .replace(/，/g, ',')\n  .split(',')\n  .map(k => k.trim())\n  .filter(k => k.length > 0);\n\nconst matchedKeyword = handoverKeywords.find(k => {\n  if (k.length === 1) return userMessage === k;   // single char: exact match\n  return userMessage.includes(k);                  // multi char: substring\n}) || null;\n\nreturn [{ json: { event, settings, userState, userMessage, matchedKeyword } }];\n"
      },
      "id": "detect",
      "name": "Detect keyword + state",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-640, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "conditions": [
            { "id": "kw", "leftValue": "={{ $json.matchedKeyword }}", "rightValue": "", "operator": { "type": "string", "operation": "exists", "singleValue": true } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-handover",
      "name": "Handover keyword?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-400, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.line.me/v2/bot/profile/{{ $json.event.userId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.settings.line_channel_access_token }}" }
