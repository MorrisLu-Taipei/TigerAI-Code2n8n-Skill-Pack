      "id": "revert-state",
      "name": "Revert is_human_mode=false",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [560, 100],
      "credentials": { "supabaseApi": { "id": "REPLACE_SUPABASE_CRED_ID", "name": "Supabase account" } },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "loose", "version": 2 }, "conditions": [ { "leftValue": "={{ $('Detect keyword + state').item.json.settings.active_ai }}", "rightValue": "gpt", "operator": { "type": "string", "operation": "equals" } } ], "combinator": "and" }, "outputKey": "gpt" },
            { "conditions": { "options": { "caseSensitive": true, "typeValidation": "loose", "version": 2 }, "conditions": [ { "leftValue": "={{ $('Detect keyword + state').item.json.settings.active_ai }}", "rightValue": "gpt", "operator": { "type": "string", "operation": "notEquals" } } ], "combinator": "and" }, "outputKey": "gemini" }
          ]
        },
        "options": {}
      },
      "id": "switch-ai",
      "name": "GPT or Gemini?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [560, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Detect keyword + state').item.json.settings.reference_file_url || 'https://example.invalid/none' }}",
        "options": { "response": { "response": { "neverError": true, "responseFormat": "text" } } }
      },
      "id": "load-ref-gpt",
      "name": "Load reference (text)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, 200],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Build the right OpenAI request by model family (ported from callGPT L114-149).\nconst base = $('Detect keyword + state').first().json;\nconst s = base.settings;\nconst fileText = (typeof $input.first().json.data === 'string') ? $input.first().json.data\n               : (typeof $input.first().json.body === 'string' ? $input.first().json.body : '');\nconst systemContent = `${s.system_prompt}\\n\\n參考文字：\\n${s.reference_text || ''}\\n\\n檔案內容：\\n${fileText || ''}`;\nconst model = s.gpt_model_name || 'gpt-4.1-mini';\nlet url, body;\nif (model.includes('gpt-5')) {\n  url = 'https://api.openai.com/v1/responses';\n  body = {\n    model,\n    input: `System: ${systemContent}\\nUser: ${base.userMessage}`,\n    reasoning: { effort: s.gpt_reasoning_effort || 'none' },\n    text: { verbosity: s.gpt_verbosity || 'medium' }\n  };\n} else {\n  url = 'https://api.openai.com/v1/chat/completions';\n  body = { model, messages: [ { role: 'system', content: systemContent }, { role: 'user', content: base.userMessage } ] };\n  if (model.startsWith('o1') || model.startsWith('o3')) {\n    body.max_completion_tokens = s.gpt_max_tokens;\n  } else {\n    body.max_tokens = s.gpt_max_tokens;\n    body.temperature = s.gpt_temperature;\n  }\n}\nreturn [{ json: { ...base, _openaiUrl: url, _openaiBody: body, _apiKey: s.gpt_api_key } }];\n"
      },
      "id": "build-gpt",
      "name": "Build GPT request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json._openaiUrl }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json._apiKey }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json._openaiBody) }}",
        "options": {}
      },
      "id": "call-gpt",
      "name": "Call OpenAI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, 200],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Normalize OpenAI response (Responses API vs chat completions).\nconst base = $('Build GPT request').first().json;\nconst r = $input.first().json || {};\nlet text = '';\nif (r.output && r.output.text) text = r.output.text;                       // /v1/responses\nelse if (Array.isArray(r.output)) {                                         // responses array form\n  const msg = r.output.find(o => o.content);\n  if (msg) text = (msg.content.find(c => c.text) || {}).text || '';\n}\nelse if (r.choices && r.choices[0]) text = r.choices[0].message?.content || '';  // chat\nelse if (r.error) text = `❌ AI 錯誤：\\n${r.error.message || JSON.stringify(r.error)}`;\nreturn [{ json: { ...base, aiText: text || '' } }];\n"
      },
      "id": "extract-gpt",
      "name": "Extract GPT text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Detect keyword + state').item.json.settings.reference_file_url || 'https://example.invalid/none' }}",
        "options": { "response": { "response": { "neverError": true, "responseFormat": "file" } } }
      },
      "id": "load-ref-gemini",
      "name": "Load reference (binary)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, 460],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Build Gemini generateContent body (ported from callGemini L152-174).\nconst base = $('Detect keyword + state').first().json;\nconst s = base.settings;\nconst userParts = [{ text: `System: ${s.system_prompt}\\nReference: ${s.reference_text || ''}` }];\nconst bin = $input.first().binary && $input.first().binary.data;\nif (bin && s.reference_file_url) {\n  const mime = String(s.reference_file_url).endsWith('.pdf') ? 'application/pdf' : 'text/plain';\n  userParts.push({ inline_data: { data: bin.data, mime_type: mime } });  // bin.data is base64\n}\nuserParts.push({ text: `User: ${base.userMessage}` });\nconst body = {\n  contents: [{ role: 'user', parts: userParts }],\n  generationConfig: { temperature: 1.0, maxOutputTokens: s.gemini_max_tokens }\n};\nconst url = `https://generativelanguage.googleapis.com/v1beta/models/${s.gemini_model_name}:generateContent?key=${s.gemini_api_key}`;\nreturn [{ json: { ...base, _geminiUrl: url, _geminiBody: body } }];\n"
      },
      "id": "build-gemini",
      "name": "Build Gemini request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1040, 460]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json._geminiUrl }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json._geminiBody) }}",
        "options": {}
      },
      "id": "call-gemini",
      "name": "Call Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1280, 460],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Normalize Gemini response.\nconst base = $('Build Gemini request').first().json;\nconst r = $input.first().json || {};\nlet text = '';\nif (r.candidates && r.candidates[0]) {\n  const part = (r.candidates[0].content?.parts || []).find(p => p.text);\n  text = part ? part.text : '';\n} else if (r.error) {\n  text = `❌ AI 錯誤：\\n${r.error.message || 'Gemini API Error'}`;\n}\nreturn [{ json: { ...base, aiText: text || '' } }];\n"
      },
      "id": "extract-gemini",
      "name": "Extract Gemini text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1520, 460]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.line.me/v2/bot/message/reply",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.settings.line_channel_access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"replyToken\": {{ JSON.stringify($json.event.replyToken) }},\n  \"messages\": [{ \"type\": \"text\", \"text\": {{ JSON.stringify(($json.aiText || '').slice(0, 4900) || '（無回應）') }} }]\n}",
        "options": {}
      },
      "id": "reply-ai",
      "name": "Reply AI text",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1760, 300],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const j = $json;\nreturn [{ json: { ok: true, userId: j.event?.userId, replied: !!j.aiText, aiText: j.aiText || '' } }];\n"
      },
      "id": "summary",
      "name": "Return summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
